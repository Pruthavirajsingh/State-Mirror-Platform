{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sansad Lok Sabha Live Ontology",
  "type": "object",
  "required": [
    "schemaVersion",
    "generatedAt",
    "source",
    "meta",
    "members",
    "parties",
    "graph"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "object",
      "required": ["name", "membersUrl", "apiUrl"],
      "properties": {
        "name": { "type": "string" },
        "membersUrl": { "type": "string" },
        "apiUrl": { "type": "string" }
      },
      "additionalProperties": true
    },
    "meta": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "members": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "party", "state", "constituency"],
        "properties": {
          "id": { "type": "string" },
          "sourceId": { "type": "string" },
          "name": { "type": "string" },
          "party": { "type": "string" },
          "partyFull": { "type": "string" },
          "state": { "type": "string" },
          "constituency": { "type": "string" },
          "profession": { "type": "string" },
          "qualification": { "type": "string" },
          "status": { "type": "string" },
          "terms": { "type": "number" },
          "age": { "type": ["number", "null"] },
          "dob": { "type": "string" },
          "imageUrl": { "type": "string" },
          "profileUrl": { "type": ["string", "null"] },
          "emails": { "type": "array", "items": { "type": "string" } },
          "phones": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "parties": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["party", "count"],
        "properties": {
          "party": { "type": "string" },
          "count": { "type": "number" },
          "states": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": true
      }
    },
    "graph": {
      "type": "object",
      "required": ["nodes", "links"],
      "properties": {
        "nodes": {
          "type": "array",
          "items": { "$ref": "#/$defs/node" }
        },
        "links": {
          "type": "array",
          "items": { "$ref": "#/$defs/link" }
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "required": ["id", "label", "type", "desc"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "type": { "type": "string" },
        "desc": { "type": "string" }
      },
      "additionalProperties": true
    },
    "link": {
      "type": "object",
      "required": ["source", "target", "type"],
      "properties": {
        "source": { "type": "string" },
        "target": { "type": "string" },
        "type": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
