{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "State Mirror Tracker Data",
  "type": "object",
  "required": [
    "schemaVersion",
    "congressMap",
    "typeColor",
    "linkColor",
    "partySymbols",
    "searchAliases"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "congressMap": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/entity"
      }
    },
    "typeColor": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/color"
      }
    },
    "linkColor": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/color"
      }
    },
    "partySymbols": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/partySymbol"
      }
    },
    "searchAliases": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "color": {
      "type": "string",
      "pattern": "^#([0-9a-fA-F]{3}|[0-9a-fA-F]{6})$"
    },
    "partySymbol": {
      "type": "object",
      "required": [
        "name",
        "image",
        "note"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "glyph": {
          "type": "string"
        },
        "image": {
          "type": "string",
          "minLength": 1
        },
        "note": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "node": {
      "type": "object",
      "required": [
        "id",
        "label",
        "type",
        "size",
        "desc"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "size": {
          "type": "number",
          "minimum": 1
        },
        "desc": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "link": {
      "type": "object",
      "required": [
        "source",
        "target",
        "type"
      ],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "alert": {
      "type": "object",
      "required": [
        "level",
        "title",
        "text"
      ],
      "properties": {
        "level": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "entity": {
      "type": "object",
      "required": [
        "id",
        "name",
        "type",
        "desc",
        "founded",
        "hq",
        "subsidiaries",
        "govtLinks",
        "globalExposure",
        "riskLevel",
        "nodes",
        "links",
        "alerts"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "desc": {
          "type": "string",
          "minLength": 1
        },
        "founded": {
          "type": ["integer", "number", "string"]
        },
        "hq": {
          "type": "string"
        },
        "subsidiaries": {
          "type": "number",
          "minimum": 0
        },
        "govtLinks": {
          "type": "number",
          "minimum": 0
        },
        "globalExposure": {
          "type": "number",
          "minimum": 0
        },
        "marketCap": {
          "type": ["string", "number"]
        },
        "riskLevel": {
          "type": "string"
        },
        "nodes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/node"
          }
        },
        "links": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/link"
          }
        },
        "alerts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/alert"
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
